# Opcional: en npm run dev ya se usa por defecto http://127.0.0.1:8000/api/v1 (sin proxy).
# Obligatorio si haces build y sirves dist sin proxy /api:
# VITE_API_URL=http://127.0.0.1:8000/api/v1

# Proxy de Vite (solo si quieres usar ruta relativa /api/v1 en dev; opcional):
# VITE_BACKEND_PROXY_URL=http://127.0.0.1:8000
